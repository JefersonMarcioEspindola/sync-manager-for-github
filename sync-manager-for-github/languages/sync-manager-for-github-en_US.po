msgid "GitHub Sync Manager"
msgstr "GitHub Sync Manager"

msgid "Você não tem permissão para acessar esta página."
msgstr "You do not have permission to access this page."

msgid "Erro de Segurança:"
msgstr "Security Error:"

msgid "Conectar Conta GitHub"
msgstr "Connect GitHub Account"

msgid "Para começar a gerenciar seus plugins hospedados no GitHub, conecte uma conta utilizando um Personal Access Token (PAT) com as devidas permissões."
msgstr "To start managing your plugins hosted on GitHub, connect an account using a Personal Access Token (PAT) with the appropriate permissions."

msgid "Qual tipo de token criar?"
msgstr "Which type of token to create?"

msgid "Classic PAT:"
msgstr "Classic PAT:"

msgid "Crie um token com o escopo "
msgstr "Create a token with the scope "

msgid "para repositórios privados e públicos"
msgstr "for private and public repositories"

msgid "ou "
msgstr "or "

msgid "somente para públicos"
msgstr "only for public"

msgid "Fine-Grained PAT (Novo):"
msgstr "Fine-Grained PAT (New):"

msgid "Selecione permissão de leitura e gravação para \"Contents\" e \"Metadata\" nos repositórios que deseja gerenciar."
msgstr "Select read and write permissions for \"Contents\" and \"Metadata\" in the repositories you want to manage."

msgid "Clique aqui para criar seu Token no GitHub"
msgstr "Click here to create your Token on GitHub"

msgid "GitHub Personal Access Token (PAT)"
msgstr "GitHub Personal Access Token (PAT)"

msgid "Conectar Conta"
msgstr "Connect Account"

msgid "Plugins Gerenciados"
msgstr "Managed Plugins"

msgid "Adicionar Plugin"
msgstr "Add Plugin"

msgid "Histórico de Logs"
msgstr "Logs History"

msgid "Configurações"
msgstr "Settings"

msgid "Verificar atualizações agora"
msgstr "Check for updates now"

msgid "Plugin"
msgstr "Plugin"

msgid "Repositório GitHub"
msgstr "GitHub Repository"

msgid "Versão Instalada"
msgstr "Installed Version"

msgid "Versão mais Recente"
msgstr "Latest Version"

msgid "Última Verificação"
msgstr "Last Check"

msgid "Status"
msgstr "Status"

msgid "Ações"
msgstr "Actions"

msgid "Exibindo apenas repositórios com código PHP principal ou com nome/descrição relacionados a plugins WordPress."
msgstr "Showing only repositories with main PHP code or with name/description related to WordPress plugins."

msgid "Buscar repositório por nome..."
msgstr "Search repository by name..."

msgid "Recarregar Repositórios"
msgstr "Reload Repositories"

msgid "Configurações do GitHub Sync"
msgstr "GitHub Sync Settings"

msgid "Conta Conectada"
msgstr "Connected Account"

msgid "Tipo de Token: %s"
msgstr "Token Type: %s"

msgid "Token Armazenado"
msgstr "Stored Token"

msgid "Idioma do Plugin"
msgstr "Plugin Language"

