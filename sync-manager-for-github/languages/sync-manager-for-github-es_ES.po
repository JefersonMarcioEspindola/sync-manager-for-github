msgstr "Acciones"

msgid "Exibindo apenas repositórios com código PHP principal ou com nome/descrição relacionados a plugins WordPress."
msgstr "Mostrando solo repositorios con código PHP principal o con nombre/descripción relacionados con plugins de WordPress."

msgid "Buscar repositório por nome..."
msgstr "Buscar repositorio por nombre..."

msgid "Recarregar Repositórios"
msgstr "Recargar Repositorios"

